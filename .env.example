# Stack identity
COMPOSE_PROJECT_NAME=ios_headers

# ClickHouse
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_NATIVE_PORT=19000
CLICKHOUSE_DB=ios_headers
CLICKHOUSE_USER=iosh
CLICKHOUSE_PASSWORD=ioshpass

# Redis
REDIS_PORT=16379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=19001
MINIO_CONSOLE_PORT=19002
MINIO_BUCKET=ios-headers

# Web
WEB_PORT=18080
VIEW_CACHE_TTL_SECONDS=2592000
SEARCH_CACHE_TTL_SECONDS=300
ENABLE_REDIS_PAGE_CACHE=false
ENABLE_SYMBOL_MATRIX=false
SHOW_QUERY_ELAPSED_MS=false

# FRP tunnel client (optional, enabled by profile: tunnel)
FRP_SERVER_ADDR=
FRP_SERVER_PORT=7000
FRP_TOKEN=replace-with-long-random-token
FRP_PROXY_NAME=ios-headers-web
FRP_REMOTE_PORT=18080

# Local bind mounts
STACK_DATA_DIR=./data
