# Stack identity
COMPOSE_PROJECT_NAME=ios_headers

# ClickHouse
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_NATIVE_PORT=19000
CLICKHOUSE_DB=ios_headers
CLICKHOUSE_USER=iosh
CLICKHOUSE_PASSWORD=ioshpass

# Redis
REDIS_PORT=16379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=19001
MINIO_CONSOLE_PORT=19002
MINIO_BUCKET=ios-headers

# Web
WEB_PORT=18080
VIEW_CACHE_TTL_SECONDS=2592000
SEARCH_CACHE_TTL_SECONDS=300
ENABLE_REDIS_PAGE_CACHE=true
SHOW_QUERY_ELAPSED_MS=true

# Local bind mounts
STACK_DATA_DIR=./data
