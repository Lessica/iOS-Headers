# Stack identity
COMPOSE_PROJECT_NAME=ios_headers

# ClickHouse
CLICKHOUSE_HTTP_PORT=18123
CLICKHOUSE_NATIVE_PORT=19000
CLICKHOUSE_DB=ios_headers
CLICKHOUSE_USER=iosh
CLICKHOUSE_PASSWORD=ioshpass

# Redis
REDIS_PORT=16379
REDIS_INSIGHT_PORT=15540

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=19001
MINIO_CONSOLE_PORT=19002
MINIO_BUCKET=ios-headers

# Local bind mounts
STACK_DATA_DIR=./data
